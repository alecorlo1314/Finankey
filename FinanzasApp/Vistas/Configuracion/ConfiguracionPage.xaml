<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FinanzasApp.Presentacion.Vistas.Configuracion.ConfiguracionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:vm="clr-namespace:FinanzasApp.Presentacion.ViewModels.Configuracion"
    Title="{Binding Titulo}"
    x:DataType="vm:ConfiguracionViewModel"
    BackgroundColor="#F5F7FA"
    IconImageSource="bs_eliminar_tarjeta.png"
    Shell.BackgroundColor="#FF006E">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">


            <!--  ENCABEZADO  -->
            <Border
                Padding="16"
                HeightRequest="112"
                StrokeShape="RoundRectangle 32"
                Style="{StaticResource TarjetaBase}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">

                    <!--  AVATAR  -->
                    <Border
                        Grid.Column="0"
                        HeightRequest="56"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 50"
                        WidthRequest="56">

                        <!--  LINEAR GRADIENT PARA UN COLOR DE FONDO  -->
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Offset="0.0" Color="#B60055" />
                                <GradientStop Offset="1.0" Color="#FF4D9A" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <!--  LETRA "A" DEL USUARIO  -->
                        <Label
                            FontFamily="PoppinsBold"
                            FontSize="24"
                            HorizontalOptions="Center"
                            Text="A"
                            TextColor="#FFFFFF"
                            VerticalOptions="Center" />
                    </Border>

                    <!--  INFORMACION DEL USUARIO  -->
                    <VerticalStackLayout
                        Grid.Column="1"
                        HorizontalOptions="Start"
                        VerticalOptions="Center">
                        <Label
                            FontFamily="InterBold"
                            FontSize="18"
                            Text="Alexander"
                            TextColor="#2C2F32" />
                        <Label
                            FontFamily="InterMedium"
                            FontSize="14"
                            Text="Finanzas personales"
                            TextColor="#595C5E" />
                    </VerticalStackLayout>
                </Grid>

            </Border>

            <!--  SECCION: SEGURIDAD  -->
            <VerticalStackLayout Spacing="8">

                <!--  TITULO SEGURIDAD  -->
                <Label
                    Style="{StaticResource TextoEtiqueta}"
                    Text="SEGURIDAD "
                    TextColor="#595C5E" />

                <!--  BIOMETRIA Y CAMBIAR CLAVE  -->
                <Border
                    Padding="16"
                    HeightRequest="112"
                    StrokeShape="RoundRectangle 32"
                    Style="{StaticResource TarjetaBase}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*">

                        <!--  ICONO BIOMETRIA Y TITULO  -->
                        <HorizontalStackLayout
                            Grid.Row="0"
                            Grid.Column="0"
                            Spacing="12">
                            <Image
                                Aspect="AspectFit"
                                HeightRequest="20"
                                HorizontalOptions="Start"
                                Source="icono_biometria.svg"
                                VerticalOptions="Center"
                                WidthRequest="20" />
                            <Label
                                FontFamily="InterMedium"
                                FontSize="16"
                                Text="Biometría"
                                TextColor="#2C2F32"
                                VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!--  SWITCH BIOMETRIA  -->
                        <buttons:SfSwitch
                            Grid.Row="0"
                            Grid.Column="1"
                            HorizontalOptions="End"
                            IsEnabled="{Binding BiometriaDisponible}"
                            IsOn="{Binding BiometriaHabilitada}"
                            VerticalOptions="Center">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="On">
                                        <VisualState.Setters>
                                            <Setter Property="SwitchSettings">
                                                <Setter.Value>
                                                    <buttons:SwitchSettings
                                                        ThumbBackground="#FFFFFF"
                                                        ThumbStroke="#FFFFFF"
                                                        TrackBackground="#3A86FF"
                                                        TrackStroke="#3A86FF" />
                                                </Setter.Value>
                                            </Setter>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Off">
                                        <VisualState.Setters>
                                            <Setter Property="SwitchSettings">
                                                <Setter.Value>
                                                    <buttons:SwitchSettings
                                                        ThumbBackground="#FFFFFF"
                                                        ThumbStroke="#FFFFFF"
                                                        TrackBackground="#FF006E"
                                                        TrackStroke="#FF006E" />
                                                </Setter.Value>
                                            </Setter>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </buttons:SfSwitch>

                        <!--  ICONO CAMBIAR CLAVE Y TITULO  -->
                        <Grid Grid.Row="1" Grid.Column="0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CambiarPinCommand}" NumberOfTapsRequired="1" />
                            </Grid.GestureRecognizers>

                            <HorizontalStackLayout Spacing="12">
                                <Image
                                    Aspect="AspectFit"
                                    HeightRequest="20"
                                    Source="icono_clave.svg"
                                    VerticalOptions="Center"
                                    WidthRequest="20" />
                                <Label
                                    FontFamily="InterMedium"
                                    FontSize="16"
                                    Text="Cambiar PIN"
                                    TextColor="#2C2F32"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>

                        <!--  ICONO FLECHA  -->
                        <Image
                            Grid.Row="1"
                            Grid.Column="1"
                            HeightRequest="24"
                            HorizontalOptions="End"
                            Source="icono_ver_detalle_tarjeta.svg"
                            VerticalOptions="Center"
                            WidthRequest="24" />
                    </Grid>
                </Border>

            </VerticalStackLayout>

            <!--  SECCION: APARIENCIA  -->
            <VerticalStackLayout Spacing="8">

                <!--  TITULO APARIENCIA  -->
                <Label
                    Style="{StaticResource TextoEtiqueta}"
                    Text="APARIENCIA"
                    TextColor="#595C5E" />

                <!--  TARJETA APARIENCIA  -->
                <Border
                    Padding="16"
                    HeightRequest="112"
                    StrokeShape="RoundRectangle 32"
                    Style="{StaticResource TarjetaBase}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*">

                        <!--  ICONO TEMA E IDIOMA ACTUAL  -->
                        <Grid Grid.Row="0" Grid.Column="0">

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CambiarTemaCommand}" NumberOfTapsRequired="1" />
                            </Grid.GestureRecognizers>

                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Image
                                    Aspect="AspectFit"
                                    HeightRequest="20"
                                    Source="icono_tema.svg"
                                    VerticalOptions="Center"
                                    WidthRequest="20" />

                                <Label
                                    FontFamily="InterMedium"
                                    FontSize="16"
                                    Text="Tema"
                                    TextColor="#2C2F32"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>

                        <!--  PILL TEMA  -->
                        <Grid
                            Grid.Row="0"
                            Grid.Column="1"
                            VerticalOptions="Center">
                            <Border
                                BackgroundColor="#D8E7FF"
                                HeightRequest="24"
                                HorizontalOptions="End"
                                StrokeShape="RoundRectangle 12"
                                VerticalOptions="Center"
                                WidthRequest="60">
                                <Label
                                    FontFamily="InterBold"
                                    FontSize="12"
                                    HorizontalOptions="Center"
                                    Text="Claro"
                                    TextColor="#3A86FF"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <!--  FILA 2: IDIOMA (icono + titulo)  -->
                        <Grid Grid.Row="1" Grid.Column="0">

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CambiarIdiomaCommand}" NumberOfTapsRequired="1" />
                            </Grid.GestureRecognizers>

                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Image
                                    Aspect="AspectFit"
                                    HeightRequest="20"
                                    Source="icono_idioma.svg"
                                    VerticalOptions="Center"
                                    WidthRequest="20" />

                                <Label
                                    FontFamily="InterMedium"
                                    FontSize="16"
                                    Text="Idioma"
                                    TextColor="#2C2F32"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>

                        <!--  LABEL IDIOMA ACTUAL (derecha)  -->
                        <Grid
                            Grid.Row="1"
                            Grid.Column="1"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
                            <Label
                                FontFamily="InterMedium"
                                FontSize="14"
                                HorizontalOptions="End"
                                Text="Español"
                                TextColor="#595C5E"
                                VerticalOptions="Center" />
                        </Grid>

                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!--  SECCION: DATOS  -->
            <VerticalStackLayout Spacing="8">

                <!--  TITULO DATOS  -->
                <Label
                    Style="{StaticResource TextoEtiqueta}"
                    Text="DATOS"
                    TextColor="#595C5E" />

                <!--  TARJETA DATOS  -->
                <Border
                    Padding="16"
                    HeightRequest="112"
                    StrokeShape="RoundRectangle 32"
                    Style="{StaticResource TarjetaBase}">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="*,*">

                        <!--  FILA 1: EXPORTAR MIS DATOS (icono + texto)  -->
                        <Grid Grid.Row="0" Grid.Column="0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ExportarDatosCommand}" NumberOfTapsRequired="1" />
                            </Grid.GestureRecognizers>

                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Image
                                    Aspect="AspectFit"
                                    HeightRequest="20"
                                    Source="icono_exportar_datos.svg"
                                    VerticalOptions="Center"
                                    WidthRequest="20" />

                                <Label
                                    FontFamily="InterMedium"
                                    FontSize="16"
                                    Text="Exportar mis datos"
                                    TextColor="#2C2F32"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>

                        <!--  ICONO FLECHA (derecha)  -->
                        <Grid
                            Grid.Row="0"
                            Grid.Column="1"
                            HorizontalOptions="End"
                            VerticalOptions="Center">
                            <Image
                                HeightRequest="24"
                                HorizontalOptions="End"
                                Source="icono_ver_detalle_tarjeta.svg"
                                VerticalOptions="Center"
                                WidthRequest="24">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ExportarDatosCommand}" NumberOfTapsRequired="1" />
                                </Image.GestureRecognizers>
                            </Image>
                        </Grid>

                        <!--  FILA 2: ELIMINAR TODOS LOS DATOS (icono + texto en color)  -->
                        <Grid Grid.Row="1" Grid.Column="0">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding LimpiarDatosCommand}" NumberOfTapsRequired="1" />
                            </Grid.GestureRecognizers>

                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Image
                                    Aspect="AspectFit"
                                    HeightRequest="20"
                                    Source="icono_eliminar_datos.svg"
                                    VerticalOptions="Center"
                                    WidthRequest="20" />

                                <Label
                                    FontFamily="InterMedium"
                                    FontSize="16"
                                    Text="Eliminar todos los datos"
                                    TextColor="#B60055"
                                    VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Grid>

                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!--  SECCION: ACERCA DE  -->
            <VerticalStackLayout Spacing="8">

                <!--  TITULO ACERCA DE  -->
                <Label
                    Style="{StaticResource TextoEtiqueta}"
                    Text="ACERCA DE"
                    TextColor="#595C5E" />

                <!--  TARJETA ACERCA DE  -->
                <Border
                    Padding="16"
                    StrokeShape="RoundRectangle 32"
                    Style="{StaticResource TarjetaBase}">
                    <Grid
                        ColumnDefinitions="*,*"
                        RowDefinitions="Auto,Auto,Auto,Auto"
                        RowSpacing="12">

                        <!--  VERSION  -->
                        <Grid
                            Grid.Row="0"
                            Grid.ColumnSpan="2"
                            ColumnDefinitions="*,*">
                            <Label
                                Grid.Column="0"
                                FontFamily="InterMedium"
                                FontSize="16"
                                Text="Versión"
                                TextColor="#595C5E"
                                VerticalOptions="Center" />

                            <Label
                                Grid.Column="1"
                                FontFamily="InterBold"
                                FontSize="14"
                                HorizontalOptions="End"
                                Text="1.0.0"
                                TextColor="#2C2F32"
                                VerticalOptions="Center" />
                        </Grid>

                        <!--  TECNOLOGIAS  -->
                        <Grid
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontFamily="InterMedium"
                                FontSize="16"
                                Text="Tecnologías"
                                TextColor="#595C5E"
                                VerticalOptions="Center" />

                            <Label
                                Grid.Column="1"
                                FontFamily="InterMedium"
                                FontSize="16"
                                HorizontalOptions="End"
                                Text=".NET MAUI 10"
                                TextColor="#2C2F32"
                                VerticalOptions="Center" />
                        </Grid>

                        <!--  SEPARADOR  -->
                        <Border
                            Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Margin="0,4,0,4"
                            BackgroundColor="#EEF1F4"
                            HeightRequest="1" />

                        <!--  TERMINOS Y PRIVACIDAD  -->
                        <Grid
                            Grid.Row="3"
                            Grid.ColumnSpan="2"
                            ColumnDefinitions="*,Auto">
                            <Label
                                Grid.Column="0"
                                FontFamily="InterMedium"
                                FontSize="16"
                                Text="Términos y privacidad"
                                TextColor="#2C2F32"
                                VerticalOptions="Center" />

                            <Image
                                Grid.Column="1"
                                HeightRequest="20"
                                HorizontalOptions="End"
                                Source="icono_terminos_condiciones.svg"
                                VerticalOptions="Center"
                                WidthRequest="20" />
                        </Grid>

                    </Grid>
                </Border>
            </VerticalStackLayout>


            <!--  MENSAJE DE ERROR  -->
            <Border
                Padding="16"
                BackgroundColor="#FEE2E2"
                IsVisible="{Binding TieneError}"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 12">
                <Label
                    FontSize="14"
                    Text="{Binding MensajeError}"
                    TextColor="{StaticResource ColorError}" />
            </Border>

            <BoxView HeightRequest="48" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
