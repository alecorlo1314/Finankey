<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="FinanzasApp.Presentacion.Vistas.Tarjetas.TarjetaFormPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:enums="clr-namespace:FinanzasApp.Domain.Enumeraciones;assembly=FinanzasApp.Domain"
    xmlns:inputs="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:FinanzasApp.Presentacion.ViewModels.Tarjetas"
    Title="{Binding Titulo}"
    x:DataType="vm:TarjetaFormViewModel"
    Shell.BackgroundColor="#FF006E">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:IsStringNotNullOrEmptyConverter x:Key="IsStringNotNullOrEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding RegresarCommand}" IsVisible="True" />
    </Shell.BackButtonBehavior>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!--  VISTA PREVIA DE LA TARJETA  -->
            <Border
                Padding="24"
                BackgroundColor="{Binding ColorHex}"
                HeightRequest="195"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 20">
                <Grid RowDefinitions="*,Auto,Auto">
                    <Label
                        Grid.Row="0"
                        HorizontalOptions="End"
                        Text="{Binding RedTarjeta}"
                        TextColor="#80FFFFFF" />
                    <Label
                        Grid.Row="1"
                        CharacterSpacing="1.5"
                        FontSize="15"
                        Text="{Binding UltimosDigitos, StringFormat='•••• •••• •••• {0}'}"
                        TextColor="White" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            FontSize="14"
                            Text="{Binding Nombre}"
                            TextColor="#CCFFFFFF" />
                        <Label
                            Grid.Column="1"
                            FontAttributes="Bold"
                            FontSize="16"
                            Text="{Binding SaldoActual, StringFormat='₡{0}'}"
                            TextColor="White" />
                    </Grid>
                </Grid>
            </Border>

            <!--  FORMULARIO  -->
            <VerticalStackLayout Spacing="16">

                <!--  Nombre  -->
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource TextoEtiqueta}" Text="Nombre de la tarjeta" />
                    <VerticalStackLayout Spacing="4">
                        <Border Style="{StaticResource EntradaContenedor}">
                            <Entry
                                MaxLength="50"
                                Placeholder="Ej: Visa Banco Nacional"
                                Style="{StaticResource EntradaTexto}"
                                Text="{Binding Nombre}" />
                        </Border>

                        <!--  Mensaje de error  -->
                        <Label
                            FontFamily="InterRegular"
                            FontSize="12"
                            IsVisible="{Binding DescripcionError, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                            Text="{Binding DescripcionError}"
                            TextColor="#FF006E" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!--  Banco  -->
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource TextoEtiqueta}" Text="Banco emisor" />
                    <VerticalStackLayout Spacing="4">
                        <Border Style="{StaticResource EntradaContenedor}">
                            <Entry
                                MaxLength="60"
                                Placeholder="Ej: Banco Nacional de Costa Rica"
                                Style="{StaticResource EntradaTexto}"
                                Text="{Binding Banco}" />
                        </Border>
                        <!--  Mensaje de error  -->
                        <Label
                            FontFamily="InterRegular"
                            FontSize="12"
                            IsVisible="{Binding BancoError, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                            Text="{Binding BancoError}"
                            TextColor="#FF006E" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!--  Últimos 4 dígitos  -->
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource TextoEtiqueta}" Text="Últimos 4 dígitos" />
                    <VerticalStackLayout Spacing="4">
                        <Border Style="{StaticResource EntradaContenedor}">
                            <Entry
                                Keyboard="Numeric"
                                MaxLength="4"
                                Placeholder="0000"
                                Style="{StaticResource EntradaTexto}"
                                Text="{Binding UltimosDigitos}" />
                        </Border>
                        <!--  Mensaje de error  -->
                        <Label
                            FontFamily="InterRegular"
                            FontSize="12"
                            IsVisible="{Binding UltimosDigitosError, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                            Text="{Binding UltimosDigitosError}"
                            TextColor="#FF006E" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!--  Fecha de vencimiento (ambos tipos)  -->
                <Grid ColumnDefinitions="*,20,*">

                    <!--  Mes del vencimiento  -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Style="{StaticResource TextoEtiqueta}" Text="Mes vencimiento" />
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Border Style="{StaticResource EntradaContenedor}">
                                <Entry
                                    Keyboard="Numeric"
                                    MaxLength="2"
                                    Placeholder="MM"
                                    Style="{StaticResource EntradaTexto}"
                                    Text="{Binding MesVencimiento}" />
                            </Border>
                            <!--  Mensaje de error  -->
                            <Label
                                FontFamily="InterRegular"
                                FontSize="12"
                                IsVisible="{Binding MesVencimientoError, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                                Text="{Binding MesVencimientoError}"
                                TextColor="#FF006E" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>

                    <!--  Separador /  -->
                    <Label
                        Grid.Column="1"
                        FontFamily="InterBold"
                        FontSize="20"
                        HorizontalOptions="Center"
                        Text="/"
                        TextColor="{StaticResource TextoDeshabilitado}"
                        VerticalOptions="Center" />

                    <!--  Mes del vencimiento  -->
                    <VerticalStackLayout Grid.Column="2" Spacing="6">
                        <Label Style="{StaticResource TextoEtiqueta}" Text="Año vencimiento" />
                        <Border Style="{StaticResource EntradaContenedor}">
                            <Entry
                                Keyboard="Numeric"
                                MaxLength="4"
                                Placeholder="AAAA"
                                Style="{StaticResource EntradaTexto}"
                                Text="{Binding AnioVencimiento}" />
                        </Border>
                        <!--  Mensaje de error  -->
                        <Label
                            FontFamily="InterRegular"
                            FontSize="12"
                            IsVisible="{Binding AnioVencimientoError, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                            Text="{Binding AnioVencimientoError}"
                            TextColor="#FF006E" />
                    </VerticalStackLayout>
                </Grid>

                <!--  Tipo de tarjeta  -->
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource TextoEtiqueta}" Text="Tipo de tarjeta" />
                    <Grid ColumnDefinitions="*,12,*" ColumnSpacing="0">
                        <!--  Botón Crédito  -->
                        <Border
                            Grid.Column="0"
                            Padding="0"
                            BackgroundColor="{Binding TipoSeleccionado, Converter={StaticResource TipoSeleccionadoColorConverter}, ConverterParameter='Credito'}"
                            Stroke="{StaticResource AzulMedio}"
                            StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SeleccionarTipoCommand}" CommandParameter="Credito" />
                            </Border.GestureRecognizers>
                            <Label
                                Padding="0,14"
                                FontAttributes="Bold"
                                FontSize="14"
                                HorizontalOptions="Center"
                                Text="Crédito"
                                TextColor="{Binding TipoSeleccionado, Converter={StaticResource TipoSeleccionadoTextoColorConverter}, ConverterParameter='Credito'}" />
                        </Border>

                        <!--  Botón Débito  -->
                        <Border
                            Grid.Column="2"
                            Padding="0"
                            BackgroundColor="{Binding TipoSeleccionado, Converter={StaticResource TipoSeleccionadoColorConverter}, ConverterParameter='Debito'}"
                            Stroke="{StaticResource AzulMedio}"
                            StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SeleccionarTipoCommand}" CommandParameter="Debito" />
                            </Border.GestureRecognizers>
                            <Label
                                Padding="0,14"
                                FontAttributes="Bold"
                                FontSize="14"
                                HorizontalOptions="Center"
                                Text="Débito"
                                TextColor="{Binding TipoSeleccionado, Converter={StaticResource TipoSeleccionadoTextoColorConverter}, ConverterParameter='Debito'}" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!--  Límite de crédito (solo crédito)  -->
                <VerticalStackLayout IsVisible="{Binding MostrarLimiteCredito}" Spacing="6">
                    <Label Style="{StaticResource TextoEtiqueta}" Text="Límite de crédito" />
                    <Border Style="{StaticResource EntradaContenedor}">
                        <Entry
                            Keyboard="Numeric"
                            Placeholder="0.00"
                            Style="{StaticResource EntradaTexto}"
                            Text="{Binding LimiteCredito}" />
                    </Border>
                </VerticalStackLayout>

                <!--  Día de corte y día de pago (solo crédito)  -->
                <VerticalStackLayout IsVisible="{Binding MostrarLimiteCredito}" Spacing="16">

                    <VerticalStackLayout Spacing="6">
                        <Label Style="{StaticResource TextoEtiqueta}" Text="Día de corte" />
                        <Border Style="{StaticResource EntradaContenedor}">
                            <Entry
                                Keyboard="Numeric"
                                MaxLength="2"
                                Placeholder="Ej: 15"
                                Style="{StaticResource EntradaTexto}"
                                Text="{Binding DiaCorte}" />
                        </Border>
                        <Label
                            FontFamily="InterRegular"
                            FontSize="12"
                            Text="Día del mes en que el banco realiza el corte"
                            TextColor="#94A3B8" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Style="{StaticResource TextoEtiqueta}" Text="Día de pago" />
                        <Border Style="{StaticResource EntradaContenedor}">
                            <Entry
                                Keyboard="Numeric"
                                MaxLength="2"
                                Placeholder="Ej: 5"
                                Style="{StaticResource EntradaTexto}"
                                Text="{Binding DiaPago}" />
                        </Border>
                        <Label
                            FontFamily="InterRegular"
                            FontSize="12"
                            Text="Día del mes siguiente al corte en que vence el pago"
                            TextColor="#94A3B8" />
                    </VerticalStackLayout>

                </VerticalStackLayout>

                <!--  Saldo actual  -->
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource TextoEtiqueta}" Text="Saldo actual" />
                    <VerticalStackLayout Spacing="4">
                        <Border Style="{StaticResource EntradaContenedor}">
                            <Entry
                                Keyboard="Numeric"
                                Placeholder="0.00"
                                Style="{StaticResource EntradaTexto}"
                                Text="{Binding SaldoActual}" />
                        </Border>
                        <!--  Mensaje de error  -->
                        <Label
                            FontFamily="InterRegular"
                            FontSize="12"
                            IsVisible="{Binding SaldoActualError, Converter={StaticResource IsStringNotNullOrEmptyConverter}}"
                            Text="{Binding SaldoActualError}"
                            TextColor="#FF006E" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!--  Red de tarjeta  -->
                <VerticalStackLayout Spacing="6">
                    <Label Style="{StaticResource TextoEtiqueta}" Text="Red de tarjeta" />
                    <Border Style="{StaticResource EntradaContenedor}">
                        <inputs:SfComboBox
                            BackgroundColor="Transparent"
                            ClearButtonIconColor="{StaticResource Gray400}"
                            DropDownBackground="White"
                            DropDownCornerRadius="20"
                            DropDownIconColor="{StaticResource Gray400}"
                            FontFamily="InterMedium"
                            FontSize="15"
                            HeightRequest="54"
                            HorizontalOptions="Start"
                            IsEditable="False"
                            ItemsSource="{Binding RedesTarjeta}"
                            Placeholder="Selecciona una red"
                            PlaceholderColor="#595C5E"
                            SelectedDropDownItemBackground="{StaticResource AzulMedio}"
                            SelectedDropDownItemTextStyle="{StaticResource TextoEtiqueta}"
                            SelectedItem="{Binding RedTarjeta, Mode=TwoWay}"
                            SelectionTextHighlightColor="White"
                            Stroke="Transparent"
                            TextColor="{StaticResource Gray600}" />
                    </Border>

                </VerticalStackLayout>

                <!--  Selector de color  -->
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource TextoEtiqueta}" Text="Color de la tarjeta" />

                    <CollectionView
                        HeightRequest="56"
                        ItemsSource="{Binding ColoresDisponibles}"
                        SelectedItem="{Binding ColorHex}"
                        SelectionMode="Single">

                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout ItemSpacing="8" Orientation="Horizontal" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">

                                <Grid
                                    Padding="6"
                                    HeightRequest="56"
                                    WidthRequest="56">
                                    <Border
                                        BackgroundColor="Transparent"
                                        HeightRequest="56"
                                        Stroke="{StaticResource AzulMedio}"
                                        StrokeShape="RoundRectangle 28"
                                        StrokeThickness="2.5"
                                        WidthRequest="56">
                                        <VisualStateManager.VisualStateGroups>
                                            <VisualStateGroupList>
                                                <VisualStateGroup x:Name="CommonStates">

                                                    <VisualState x:Name="Normal">
                                                        <VisualState.Setters>
                                                            <Setter Property="Opacity" Value="0" />
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                    <VisualState x:Name="Selected">
                                                        <VisualState.Setters>
                                                            <Setter Property="Opacity" Value="1" />
                                                        </VisualState.Setters>
                                                    </VisualState>

                                                </VisualStateGroup>
                                            </VisualStateGroupList>
                                        </VisualStateManager.VisualStateGroups>
                                    </Border>

                                    <Border
                                        BackgroundColor="{Binding .}"
                                        HeightRequest="44"
                                        HorizontalOptions="Center"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 22"
                                        VerticalOptions="Center"
                                        WidthRequest="44" />

                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList>
                                            <VisualStateGroup x:Name="CommonStates">

                                                <VisualState x:Name="Normal">
                                                    <VisualState.Setters>
                                                        <Setter Property="Scale" Value="1.0" />
                                                    </VisualState.Setters>
                                                </VisualState>

                                                <VisualState x:Name="Selected">
                                                    <VisualState.Setters>
                                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                                        <Setter Property="Scale" Value="1.1" />
                                                    </VisualState.Setters>
                                                </VisualState>

                                            </VisualStateGroup>
                                        </VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!--  MENSAJE DE ERROR  -->
            <Border
                Padding="16"
                BackgroundColor="#FEE2E2"
                IsVisible="{Binding TieneError}"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 12">
                <Label
                    FontSize="14"
                    Text="{Binding MensajeError}"
                    TextColor="{StaticResource ColorError}" />
            </Border>

            <!--  BOTONE DE GUARDAR  -->
            <Button
                Margin="0,8,0,32"
                Command="{Binding GuardarCommand}"
                IsEnabled="{Binding EsFormularioValido}"
                Style="{StaticResource BotonPrimario}"
                Text="Guardar tarjeta" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
