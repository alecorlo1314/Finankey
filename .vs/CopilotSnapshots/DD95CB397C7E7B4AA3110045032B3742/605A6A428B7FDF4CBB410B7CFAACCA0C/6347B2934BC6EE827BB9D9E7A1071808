<?xml version="1.0" encoding="utf-8" ?>
<!--
    DashboardPage.xaml — Pantalla principal de la app.
    Muestra: saludo, resumen financiero del mes, carrusel de tarjetas
    y las últimas transacciones.
-->
<ContentPage
    x:Class="FinanzasApp.Presentacion.Vistas.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:FinanzasApp.Presentacion.ViewModels"
    x:DataType="vm:DashboardViewModel"
    Shell.NavBarIsVisible="False">

    <ContentPage.Behaviors>
        <!--  Llama a AlAparecerAsync cada vez que la página se muestra  -->
        <toolkit:EventToCommandBehavior Command="{Binding CargarDashboardCommand}" EventName="Appearing" />
        <toolkit:StatusBarBehavior StatusBarColor="{StaticResource AzulPrimario}" StatusBarStyle="LightContent" />
    </ContentPage.Behaviors>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!--  ── Header con gradiente ────────────────────────────────────  -->
            <Grid Padding="24,32,24,32" BackgroundColor="{StaticResource AzulPrimario}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Saludo  -->
                <Label
                    Grid.Row="0"
                    Style="{StaticResource TextoCuerpo}"
                    Text="{Binding SaludoUsuario}"
                    TextColor="#B0C4DE" />

                <!--  Balance del mes  -->
                <Label
                    Grid.Row="1"
                    Style="{StaticResource TextoMoneda}"
                    Text="{Binding ResumenFinanciero.BalanceMes, StringFormat='₡{0:N0}'}"
                    TextColor="White" />

                <!--  Selector de mes  -->
                <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto">
                    <Button
                        Grid.Column="0"
                        Padding="0"
                        BackgroundColor="Transparent"
                        Command="{Binding MesAnteriorCommand}"
                        FontSize="22"
                        Text="‹"
                        TextColor="#B0C4DE"
                        WidthRequest="36" />

                    <Label
                        Grid.Column="1"
                        FontSize="13"
                        HorizontalOptions="Center"
                        Text="{Binding EtiquetaMes}"
                        TextColor="#B0C4DE"
                        VerticalOptions="Center" />

                    <Button
                        Grid.Column="2"
                        Padding="0"
                        BackgroundColor="Transparent"
                        Command="{Binding MesSiguienteCommand}"
                        FontSize="22"
                        Text="›"
                        TextColor="#B0C4DE"
                        WidthRequest="36" />
                </Grid>
            </Grid>

            <!--  ── Tarjetas de resumen (gastos / ingresos) ─────────────────  -->
            <Grid Margin="16,-24,16,0" ColumnDefinitions="*,8,*">

                <!--  Gastos del mes  -->
                <Border
                    Grid.Column="0"
                    Padding="16"
                    Style="{StaticResource TarjetaBase}">
                    <VerticalStackLayout Spacing="4">
                        <Label Style="{StaticResource TextoEtiqueta}" Text="💸 Gastos" />
                        <Label
                            Style="{StaticResource TextoMonedaChico}"
                            Text="{Binding ResumenFinanciero.GastosMesActual, StringFormat='₡{0:N0}'}"
                            TextColor="{StaticResource ColorGasto}" />
                    </VerticalStackLayout>
                </Border>

                <!--  Ingresos del mes  -->
                <Border
                    Grid.Column="2"
                    Padding="16"
                    Style="{StaticResource TarjetaBase}">
                    <VerticalStackLayout Spacing="4">
                        <Label Style="{StaticResource TextoEtiqueta}" Text="💰 Ingresos" />
                        <Label
                            Style="{StaticResource TextoMonedaChico}"
                            Text="{Binding ResumenFinanciero.IngresosMesActual, StringFormat='₡{0:N0}'}"
                            TextColor="{StaticResource ColorIngreso}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!--  ── Sección de tarjetas ──────────────────────────────────────  -->
            <VerticalStackLayout Padding="24,20,24,0" Spacing="12">
                <Label Style="{StaticResource TextoSubtitulo}" Text="Mis tarjetas" />

                <!--  CarouselView horizontal de tarjetas  -->
                <CarouselView
                    HeightRequest="160"
                    ItemsSource="{Binding Tarjetas}"
                    Loop="False"
                    PeekAreaInsets="20">
                    <CarouselView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Margin="4"
                                Padding="20"
                                BackgroundColor="{Binding ColorHex}"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 20">
                                <Grid RowDefinitions="*,Auto,Auto">
                                    <!--  Red de la tarjeta  -->
                                    <Label
                                        Grid.Row="0"
                                        FontSize="13"
                                        HorizontalOptions="End"
                                        Text="{Binding RedTarjeta}"
                                        TextColor="#80FFFFFF" />

                                    <!--  Últimos dígitos  -->
                                    <Label
                                        Grid.Row="1"
                                        Margin="0,0,0,8"
                                        CharacterSpacing="1.5"
                                        FontSize="14"
                                        Text="{Binding UltimosDigitos, StringFormat='•••• •••• •••• {0}'}"
                                        TextColor="White" />

                                    <!--  Nombre y saldo  -->
                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto">
                                        <Label
                                            Grid.Column="0"
                                            FontSize="13"
                                            Text="{Binding Nombre}"
                                            TextColor="#CCFFFFFF" />
                                        <Label
                                            Grid.Column="1"
                                            FontAttributes="Bold"
                                            FontSize="16"
                                            Text="{Binding SaldoActual, StringFormat='₡{0:N0}'}"
                                            TextColor="White" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                </CarouselView>
            </VerticalStackLayout>

            <!--  ── Últimas transacciones ────────────────────────────────────  -->
            <VerticalStackLayout Padding="24,24,24,32" Spacing="12">
                <Label Style="{StaticResource TextoSubtitulo}" Text="Últimos movimientos" />

                <!--  ActivityIndicator mientras carga  -->
                <ActivityIndicator
                    IsRunning="{Binding EstaCargando}"
                    IsVisible="{Binding EstaCargando}"
                    Color="{StaticResource AzulMedio}" />

                <!--  Lista de transacciones recientes  -->
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding TransaccionesRecientes}" Spacing="8">
                    <BindableLayout.EmptyView>
                        <Label
                            Margin="0,24"
                            HorizontalOptions="Center"
                            Style="{StaticResource TextoCuerpo}"
                            Text="Sin movimientos recientes" />
                    </BindableLayout.EmptyView>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <!--  Fila de transacción  -->
                            <Border Padding="16,12" Style="{StaticResource TarjetaBase}">
                                <Grid ColumnDefinitions="40,*,Auto" ColumnSpacing="12">
                                    <!--  Icono de categoría  -->
                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="{StaticResource AzulPastel}"
                                        HeightRequest="40"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 12"
                                        WidthRequest="40">
                                        <Label
                                            FontSize="18"
                                            HorizontalOptions="Center"
                                            Text="{Binding Categoria, Converter={StaticResource CategoriaIconoConverter}}"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <!--  Descripción y fecha  -->
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="2"
                                        VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            LineBreakMode="TailTruncation"
                                            Style="{StaticResource TextoCuerpo}"
                                            Text="{Binding Descripcion}"
                                            TextColor="{StaticResource TextoPrimario}" />
                                        <Label
                                            FontSize="12"
                                            Style="{StaticResource TextoCuerpo}"
                                            Text="{Binding Fecha, StringFormat='{0:dd MMM yyyy}'}" />
                                    </VerticalStackLayout>

                                    <!--  Monto con color según tipo  -->
                                    <Label
                                        Grid.Column="2"
                                        FontAttributes="Bold"
                                        FontSize="15"
                                        Text="{Binding Monto, Converter={StaticResource MontoConSignoConverter}}"
                                        TextColor="{Binding Tipo, Converter={StaticResource TipoTransaccionColorConverter}}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
